@model Shashlik.EventBus.Dashboard.Areas.ShashlikEventBus.Models.MessageViewModel

<div class="login-card">
    <h2>EventBus Dashboard</h2>
    <p>Enter the dashboard secret to access the event bus management panel.</p>
    <form method="post" enctype="multipart/form-data">
        <div class="mb-3">
            <input type="password" name="Secret" class="form-control" placeholder="Secret" autofocus>
        </div>
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger py-2" style="font-size:.85rem;">@ViewBag.Error</div>
        }
        <button class="btn btn-primary w-100" type="submit">Login</button>
    </form>
</div>