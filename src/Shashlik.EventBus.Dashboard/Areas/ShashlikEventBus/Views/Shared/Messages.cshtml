@using System.Reflection
@using Shashlik.EventBus
@using Shashlik.EventBus.Dashboard
@model Shashlik.EventBus.Dashboard.Areas.ShashlikEventBus.Models.MessageViewModel
@inject UrlService UrlService

<div class="container-fluid">
    <main class="px-md-4 pt-3 main-content main-content-full">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h4 class="mb-0" style="font-weight:700;color:#1e1b4b;">@ViewBag.Title Messages</h4>
            <button type="button" class="btn btn-retry btn-sm" id="retryBtn">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-arrow-clockwise me-1" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.418A6 6 0 1 1 8 2v1z"/><path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z"/></svg>
                Retry Selected
            </button>
        </div>

        <div class="filter-card">
            <form class="row g-2 align-items-end" method="get" id="searchForm">
                <div class="col-lg-2 col-md-4 col-6">
                    <label class="form-label mb-1">Begin Time</label>
                    <input type="date" class="form-control form-control-sm" name="beginTime" id="beginTimeInput" value="@Model.BeginTime.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-lg-2 col-md-4 col-6">
                    <label class="form-label mb-1">End Time</label>
                    <input type="date" class="form-control form-control-sm" name="endTime" id="endTimeInput" value="@Model.EndTime.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-lg-2 col-md-4 col-6">
                    <label class="form-label mb-1">Status</label>
                    <select class="form-select form-select-sm" name="status">
                        <option value="" selected="@(string.IsNullOrEmpty(Model.Status))">All</option>
                        <option value="@MessageStatus.Scheduled" selected="@(Model.Status == MessageStatus.Scheduled)">@MessageStatus.Scheduled</option>
                        <option value="@MessageStatus.Succeeded" selected="@(Model.Status == MessageStatus.Succeeded)">@MessageStatus.Succeeded</option>
                        <option value="@MessageStatus.Failed" selected="@(Model.Status == MessageStatus.Failed)">@MessageStatus.Failed</option>
                    </select>
                </div>
                <div class="col-lg-2 col-md-4 col-6">
                    <label class="form-label mb-1">Event Name</label>
                    <input type="text" class="form-control form-control-sm" name="eventName" placeholder="Search event name" value="@Model.EventName">
                </div>
                @if (ViewBag.Page == "Received")
                {
                    <div class="col-lg-2 col-md-4 col-12">
                        <label class="form-label mb-1">Handler Name</label>
                        <input type="text" class="form-control form-control-sm" name="eventHandlerName" placeholder="Search handler name" value="@Model.EventHandlerName">
                    </div>
                }
                <div class="col-lg-2 col-md-4 col-12">
                    <button type="submit" class="btn btn-retry btn-sm w-100">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-search me-1" viewBox="0 0 16 16"><path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/></svg>
                        Search
                    </button>
                </div>
            </form>
        </div>

        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                    <tr>
                        <th scope="col" style="width:30px;">
                            <input type="checkbox" id="selectAll" class="form-check-input"/>
                        </th>
                        <th scope="col">MsgId</th>
                        <th scope="col">EventName</th>
                        <th scope="col">EventHandler</th>
                        <th scope="col">Status</th>
                        <th scope="col">Retry</th>
                        <th scope="col">CreateTime</th>
                        <th scope="col">DelayAt</th>
                        <th scope="col">ExpireTime</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var message in Model.Messages)
                    {
                        <tr>
                            <td>
                                <input type="checkbox" value="@message.Id" class="form-check-input row-check"/>
                            </td>
                            <td>
                                <a href="#" data-bs-toggle="modal" data-bs-target="#modal_@message.Id" style="color:#4f46e5;font-size:.85rem;">@message.MsgId</a>
                                <div class="modal fade modal-xl" id="modal_@message.Id" tabindex="-1" aria-hidden="true">
                                    <div class="modal-dialog">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title" style="font-size:.95rem;">@message.ToString()</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                <table class="table table-sm table-bordered mb-0">
                                                    @foreach (var prop in message.GetType().GetProperties(BindingFlags.Public | BindingFlags.Instance))
                                                    {
                                                        <tr><td style="width:180px;font-weight:600;font-size:.8rem;color:#6b7280;">@prop.Name</td><td style="font-size:.85rem;">@prop.GetValue(message)</td></tr>
                                                    }
                                                </table>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Close</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td style="font-size:.85rem;">@message.EventName</td>
                            <td style="font-size:.85rem;">@message.EventHandlerName</td>
                            <td><span class="status-badge status-@message.Status">@message.Status</span></td>
                            <td style="font-size:.85rem;">@message.RetryCount</td>
                            <td style="font-size:.8rem;color:#6b7280;">@message.CreateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td style="font-size:.8rem;color:#6b7280;">@message.DelayAt?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td style="font-size:.8rem;color:#6b7280;">@message.ExpireTime?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                    }
                    @if (Model.Messages.Count == 0)
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">No messages found.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <nav class="mt-3" aria-label="Page navigation">
            <div class="row align-items-center">
                <div class="col-sm-12 col-md-4">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            Page size: @Model.PageSize
                        </button>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="@UrlService.CurrentUrl("pageSize", "10")">10</a></li>
                            <li><a class="dropdown-item" href="@UrlService.CurrentUrl("pageSize", "20")">20</a></li>
                            <li><a class="dropdown-item" href="@UrlService.CurrentUrl("pageSize", "50")">50</a></li>
                            <li><a class="dropdown-item" href="@UrlService.CurrentUrl("pageSize", "100")">100</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-sm-12 col-md-8">
                    <ul class="pagination justify-content-end mb-0" style="font-size:.85rem;">
                        <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                            <a class="page-link" href="@(Model.PageIndex > 1 ? UrlService.CurrentUrl("pageIndex", (Model.PageIndex - 1).ToString()) : "#")">&laquo;</a>
                        </li>
                        @for (var p = Model.PageIndex - 3; p <= Model.PageIndex + 3; p++)
                        {
                            if (p < 1 || p > Model.TotalPage)
                            {
                                continue;
                            }
                            <li class="page-item @(Model.PageIndex == p ? "active" : "")">
                                <a class="page-link" href="@UrlService.CurrentUrl("pageIndex", p.ToString())">@p</a>
                            </li>
                        }
                        <li class="page-item @(Model.PageIndex >= Model.TotalPage ? "disabled" : "")">
                            <a class="page-link" href="@(Model.PageIndex < Model.TotalPage ? UrlService.CurrentUrl("pageIndex", (Model.PageIndex + 1).ToString()) : "#")">&raquo;</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </main>
</div>
<script>
    // Ensure beginTime/endTime/status are preserved when clicking pagination, page size, or nav links
    (function() {
        var bt = "@Model.BeginTime.ToString("yyyy-MM-dd")";
        var et = "@Model.EndTime.ToString("yyyy-MM-dd")";
        var st = "@Model.Status";
        function addDateParams(href) {
            if (!href || href === '#' || href.startsWith('javascript')) return href;
            var sep = href.indexOf('?') >= 0 ? '&' : '?';
            if (href.indexOf('beginTime=') < 0) {
                href += sep + 'beginTime=' + encodeURIComponent(bt);
                sep = '&';
            }
            if (href.indexOf('endTime=') < 0) {
                href += sep + 'endTime=' + encodeURIComponent(et);
                sep = '&';
            }
            if (st && href.indexOf('status=') < 0) {
                href += sep + 'status=' + encodeURIComponent(st);
            }
            return href;
        }
        document.querySelectorAll('.pagination a, .dropdown-item, .navbar a').forEach(a => {
            var orig = a.getAttribute('href');
            if (orig) a.setAttribute('href', addDateParams(orig));
        });

        document.getElementById("selectAll").onchange = function(evt) {
            document.querySelectorAll('.row-check').forEach(input => {
                input.checked = evt.target.checked;
            });
        }

        document.getElementById("retryBtn").onclick = function() {
            @if (ViewBag.Page == "Published")
            {
            @:var url = "@Url.Action("Retry", "Published")";
            }
            else if (ViewBag.Page == "Received")
            {
            @:var url = "@Url.Action("Retry", "Received")";
            }
            var ids = [];
            document.querySelectorAll('.row-check').forEach(input => {
                if (input.checked) {
                    ids.push("ids=" + input.value);
                }
            });
            if (ids.length === 0) {
                return false;
            }
            var query = ids.join('&');
            fetch(url + "?" + query, { method: 'POST' }).then(r => {
                if (r.ok) {
                    alert("Retry request sent successfully.");
                    location.reload();
                } else {
                    alert("Retry request failed.");
                }
            });
            return false;
        }

    })();
</script>
